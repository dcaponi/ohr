# --- Database ---
# Local Docker Postgres (pgvector). Host port is 5433 to avoid clashing with a
# local Postgres on 5432. In production, replace with your NeonDB connection string.
DATABASE_URL="postgres://ohr:ohr@localhost:5433/ohr"

# --- Anthropic (LLM: query planning, answering, LLM-as-judge) ---
# Fill this in. Model used: claude-opus-4-8
ANTHROPIC_API_KEY=""

# --- OpenAI (embeddings only: text-embedding-3-small, 1536-dim) ---
# Anthropic has no embeddings API, so embeddings come from OpenAI.
OPENAI_API_KEY=""

# --- Cron auth (optional) ---
# If set, the cron endpoints require header:  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""
